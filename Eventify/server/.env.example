# Copy this file to ".env" and fill in the integration user credentials.

# Port the API server listens on (5002 so it can run alongside the other apps)
PORT=5002

# Salesforce login URL
#   https://login.salesforce.com   -> production / Developer Edition orgs
#   https://test.salesforce.com    -> sandboxes
SF_LOGIN_URL=https://login.salesforce.com

# Integration user for the PUBLIC site (event list + registrations).
# Visitors never log in; the server performs these operations with this
# account. In a Developer org, your own credentials work fine.
SF_USERNAME=
SF_PASSWORD=
SF_TOKEN=
