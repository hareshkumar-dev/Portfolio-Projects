<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Asset Tracker User</label>
    <description>Access to the Stock Item object, its fields, and the dashboard Apex controller.</description>
    <hasActivationRequired>false</hasActivationRequired>

    
    <tabSettings>
        <tab>Stock_Dashboard</tab>
        <visibility>Visible</visibility>
    </tabSettings>
<objectPermissions>
        <object>Stock_Item__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <fieldPermissions>
        <field>Stock_Item__c.SKU__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Stock_Item__c.Category__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Stock_Item__c.Quantity_On_Hand__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Stock_Item__c.Reorder_Point__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Stock_Item__c.Unit_Cost__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Stock_Item__c.Stock_Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Stock_Item__c.Needs_Reorder__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Stock_Item__c.Last_Checked__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <classAccesses>
        <apexClass>StockController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StockLevelBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StockLevelScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
