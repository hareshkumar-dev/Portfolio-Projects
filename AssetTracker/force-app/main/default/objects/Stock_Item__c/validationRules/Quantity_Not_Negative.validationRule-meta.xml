<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Quantity_Not_Negative</fullName>
    <active>true</active>
    <description>Quantity on hand cannot be negative.</description>
    <errorConditionFormula>Quantity_On_Hand__c &lt; 0</errorConditionFormula>
    <errorDisplayField>Quantity_On_Hand__c</errorDisplayField>
    <errorMessage>Quantity on hand cannot be negative.</errorMessage>
</ValidationRule>
