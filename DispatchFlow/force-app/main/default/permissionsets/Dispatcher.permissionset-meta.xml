<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Dispatcher</label>
    <description>Access to technicians, work orders, assignment logs, logs, and the dispatch console.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <tabSettings>
        <tab>Dispatch_Console</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <objectPermissions>
        <object>Technician__c</object>
        <allowCreate>true</allowCreate><allowRead>true</allowRead><allowEdit>true</allowEdit><allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords><modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Work_Order__c</object>
        <allowCreate>true</allowCreate><allowRead>true</allowRead><allowEdit>true</allowEdit><allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords><modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Assignment_Log__c</object>
        <allowCreate>true</allowCreate><allowRead>true</allowRead><allowEdit>false</allowEdit><allowDelete>false</allowDelete>
        <viewAllRecords>true</viewAllRecords><modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Log__c</object>
        <allowCreate>true</allowCreate><allowRead>true</allowRead><allowEdit>false</allowEdit><allowDelete>false</allowDelete>
        <viewAllRecords>true</viewAllRecords><modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <fieldPermissions><field>Technician__c.Skills__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Technician__c.Territory__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Technician__c.Max_Jobs__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Technician__c.Active_Jobs__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Technician__c.Is_Available__c</field><readable>true</readable><editable>true</editable></fieldPermissions>

    <!-- Subject__c is a required field; permission sets cannot grant FLS on required fields (always visible). -->
    <fieldPermissions><field>Work_Order__c.Required_Skill__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Work_Order__c.Territory__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Work_Order__c.Priority__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Work_Order__c.Status__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Work_Order__c.Assigned_Technician__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Work_Order__c.Match_Score__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Work_Order__c.Scheduled_Date__c</field><readable>true</readable><editable>true</editable></fieldPermissions>

    <fieldPermissions><field>Assignment_Log__c.Work_Order__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Assignment_Log__c.Technician__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Assignment_Log__c.Match_Score__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Assignment_Log__c.Candidates_Considered__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Assignment_Log__c.Reason__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Assignment_Log__c.Logged_At__c</field><readable>true</readable><editable>true</editable></fieldPermissions>

    <fieldPermissions><field>Log__c.Level__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Log__c.Context__c</field><readable>true</readable><editable>true</editable></fieldPermissions>
    <fieldPermissions><field>Log__c.Message__c</field><readable>true</readable><editable>true</editable></fieldPermissions>

    <classAccesses><apexClass>DispatchConsoleController</apexClass><enabled>true</enabled></classAccesses>
    <classAccesses><apexClass>RebalanceBatch</apexClass><enabled>true</enabled></classAccesses>
    <classAccesses><apexClass>RebalanceScheduler</apexClass><enabled>true</enabled></classAccesses>
</PermissionSet>
