<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>No_Future_Dates</fullName>
    <active>true</active>
    <description>An expense cannot be dated in the future.</description>
    <errorConditionFormula>AND(NOT(ISBLANK(Expense_Date__c)), Expense_Date__c &gt; TODAY())</errorConditionFormula>
    <errorDisplayField>Expense_Date__c</errorDisplayField>
    <errorMessage>Expense date cannot be in the future.</errorMessage>
</ValidationRule>
