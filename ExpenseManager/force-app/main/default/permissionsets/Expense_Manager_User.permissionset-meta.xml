<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Expense Manager User</label>
    <description>Access to the Expense Manager objects, fields, and Apex controller.</description>
    <hasActivationRequired>false</hasActivationRequired>

    
    <tabSettings>
        <tab>Expense_Manager</tab>
        <visibility>Visible</visibility>
    </tabSettings>
<objectPermissions>
        <object>Expense_Report__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Expense_Line__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <fieldPermissions>
        <field>Expense_Report__c.Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Expense_Report__c.Total_Amount__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Expense_Report__c.Employee__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Expense_Report__c.Submitted_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Expense_Report__c.Purpose__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <fieldPermissions>
        <field>Expense_Line__c.Category__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Expense_Line__c.Expense_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Expense_Line__c.Merchant__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Expense_Line__c.Notes__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <classAccesses>
        <apexClass>ExpenseController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ExpenseRollupService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
