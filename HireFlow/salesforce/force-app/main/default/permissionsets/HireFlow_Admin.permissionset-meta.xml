        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Application__c.Stage_Changed_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Application__c.Cover_Note__c</field>
        <readable>true</readable>
        <editable>true</editable>
