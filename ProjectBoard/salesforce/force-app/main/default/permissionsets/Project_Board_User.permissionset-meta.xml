<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Project Board User</label>
    <description>Access to the Project Task object, its fields, and the board Apex controller.</description>
    <hasActivationRequired>false</hasActivationRequired>

    
    <tabSettings>
        <tab>Project_Board</tab>
        <visibility>Visible</visibility>
    </tabSettings>
<objectPermissions>
        <object>Project_Task__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <fieldPermissions>
        <field>Project_Task__c.Stage__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Project_Task__c.Assignee__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Project_Task__c.Priority__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Project_Task__c.Due_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Project_Task__c.Description__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <classAccesses>
        <apexClass>ProjectBoardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
