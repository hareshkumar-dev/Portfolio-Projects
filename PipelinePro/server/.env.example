# Copy to .env and fill in your values. NEVER commit the real .env.

# Port the API server listens on
PORT=5001

# Salesforce login URL (Developer Edition / production)
SF_LOGIN_URL=https://login.salesforce.com

# Org alias whose Salesforce CLI session backs public (no-login) routes.
# Only needed for apps with a public tier (Eventify/ShopTrack/HireFlow/EstateHub).
SF_ORG=your_org_alias

# OAuth 2.0 Connected App (web-server flow + PKCE) — your app's consumer key
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CALLBACK_URL=http://localhost:5001/api/auth/callback
CLIENT_URL=http://localhost:3001
