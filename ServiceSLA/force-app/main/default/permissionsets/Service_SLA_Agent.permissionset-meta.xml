<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Service SLA Agent</label>
    <description>Access to the SLA Case fields, the Log object, and the SLA console controller.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <tabSettings>
        <tab>SLA_Command_Center</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <objectPermissions>
        <object>Log__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <fieldPermissions>
        <field>Case.Service_Tier__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.Response_Target__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.Resolution_Target__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.First_Responded_At__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.SLA_Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.Is_Escalated__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <fieldPermissions>
        <field>Log__c.Level__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Log__c.Context__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Log__c.Message__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <classAccesses>
        <apexClass>SlaConsoleController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SlaEscalationBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SlaEscalationScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
